.build:
  stage: build
  tags: 
    - common_runner

  image: 
    name: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/gradle-9.3.0-jdk-21:v4

#    pull_policy: always  
  script:
    - pwd
    - ls -la
    - |
      if [ -n "$VERSION" ]; then
        echo "version ${VERSION}"
        gradle build -x test -Pversion=${VERSION} --info
      else
        gradle build -x test --info

      fi
    - ls -lrth
    - ls -lrth build/libs
  artifacts:
    paths:
      - build/libs
    when: on_success 
    expire_in: 1 week

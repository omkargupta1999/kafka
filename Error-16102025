FROM registry.access.redhat.com/ubi9/openjdk-21

USER root

RUN mkdir -p /app
WORKDIR /app

# ✅ FIX: Copy Gradle correctly into /app/gradle
COPY gradle-8.9/ /app/gradle/

# ✅ Correct Gradle path
ENV GRADLE_HOME=/app/gradle
ENV PATH=$PATH:$GRADLE_HOME/bin

# Copy gradle.properties
COPY ./gradle.properties /app/gradle/

# ✅ REMOVE proxy settings
RUN sed -i '/systemProp.http.proxyHost/d' /app/gradle/gradle.properties && \
    sed -i '/systemProp.http.proxyPort/d' /app/gradle/gradle.properties && \
    sed -i '/systemProp.https.proxyHost/d' /app/gradle/gradle.properties && \
    sed -i '/systemProp.https.proxyPort/d' /app/gradle/gradle.properties

# Permissions
RUN chmod -R 777 /app/

# Debug (optional)
RUN ls -lrth /app/
RUN ls -lrth /app/gradle/

# ❌ Do NOT copy application (for reusable image)
# COPY ./epay_transaction_service/ /app/

# ❌ Do NOT run bootRun (CI will control execution)
# ENTRYPOINT ["gradle", "bootRun", "--debug"]

# ✅ Default entrypoint for CI
ENTRYPOINT ["gradle"]

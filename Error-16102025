FROM registry.access.redhat.com/ubi9/openjdk-21:latest

USER root

# Install unzip (used for gradle setup)
RUN dnf install -y unzip || true

# Create gradle directory
RUN mkdir -p /opt/gradle/

# Copy Gradle distribution
COPY gradle-8.9/ /opt/gradle/

# Set Gradle environment
ENV GRADLE_HOME=/opt/gradle
ENV PATH=$PATH:$GRADLE_HOME/bin

# Copy gradle.properties (custom config)
COPY gradle.properties /opt/gradle/

# Set permissions
RUN chmod -R 777 /opt/gradle

# Copy certificate (for internal SSL trust)
COPY gitlab.epay.sbi.crt /tmp/

# Import certificate into Java truststore
RUN keytool -import -trustcacerts \
    -file /tmp/gitlab.epay.sbi.crt \
    -keystore /usr/lib/jvm/java-21/lib/security/cacerts \
    -alias SBI-GITLAB \
    -storepass changeit -noprompt

# Set working directory
WORKDIR /app

# Default command
CMD ["bash"]


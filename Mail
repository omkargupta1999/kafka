resources:
  requests:
    memory: "2Gi"
    cpu: "1000m"
  limits:
    memory: "4Gi"
    cpu: "2000m"
ingress: {}

# Enable health probes for proper HPA functioning
readinessProbe:
  enabled: false
  httpGet:
    path: "/api/transaction/v1/actuator/health/readiness"
    port: 9092
    scheme: HTTP
  initialDelaySeconds: 60
  periodSeconds: 10

livenessProbe:
  enabled: false
  httpGet:
    path: "/api/transaction/v1/actuator/health/liveness"
    port: 9092
    scheme: HTTP
  initialDelaySeconds: 30
  periodSeconds: 10

## HPA Configuration
hpa:
  enabled: true
  minReplicas: 1
  maxReplicas: 6
  targetCPUUtilizationPercentage: 70
  targetMemoryUtilizationPercentage: 80
  behavior:
    scaleUp:
      stabilizationWindowSeconds: 60
      policies:
      - type: Percent
        value: 50
        periodSeconds: 60
    scaleDown:
      stabilizationWindowSeconds: 300
      policies:
      - type: Percent
        value: 10
        periodSeconds: 60

autoscaling:
  enabled: true

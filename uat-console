apiVersion: console.streamshub.github.com/v1alpha1
kind: Console
metadata:
  name: uat-console
  namespace: uat-kafka
spec:
  hostname: uat-kafkaconsole.apps.uat.epay.sbi

  kafkaClusters:
    - name: uat-kafka-cluster
      namespace: uat-kafka
      listener: plain

      credentials:
        kafkaUser:
          name: epay-user

      # Common Kafka client configs
      properties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      adminProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      consumerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      producerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT

  # Uses OpenShift Monitoring (no internal Prometheus)
  metricsSources:
    - name: k8s
      type: openshift-monitoring

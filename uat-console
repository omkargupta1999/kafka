apiVersion: console.streamshub.github.com/v1alpha1
kind: Console
metadata:
  name: uat-console
  namespace: uat-kafka

spec:
  hostname: uat-kafkaconsole.apps.uat.epay.sbi

  kafkaClusters:
    - name: uat-kafka-cluster
      namespace: uat-kafka
      listener: plain

      # ✅ NO credentials (match DEV)
      
      properties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      adminProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: '30000'
          - name: default.api.timeout.ms
            value: '30000'

      consumerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: '30000'

      producerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: '30000'

  # ✅ SAME as DEV (key fix)
  metricsSources:
    - name: k8s
      type: openshift-monitoring

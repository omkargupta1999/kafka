fetch_config:
  stage: validate
  image: ${IMAGE_REGISTRY}/library/rhelgit:latest
  needs:
    - job: validate_service
      artifacts: true
  script:
    - |
      if [ "$SKIP_PIPELINE" = "true" ]; then
        echo "Skipping fetch_config as no chart changes detected"
        exit 0
      fi
      set -eo pipefail
      echo "Cloning external config repo..."
      git config --global http.sslVerify false
      git config --global --add safe.directory '*'
      git config --global user.name "ci"
      git config --global user.email "ci.cedge@sbi.co.in"    

      echo "Using PAT for clone..."
      echo "Project path: epay/application/Config"

      git clone https://oauth2:${GIT_PAT}@gitlab.epay.sbi/epay/application/config/epay_backend_config.git

      echo "Checking config path..."

      # CONFIG TYPE RESOLUTION (FINAL VERSION)

      # Step 1: Auto-detect if not explicitly provided
      if [ -z "$CONFIG_TYPE" ] || [ "$CONFIG_TYPE" = "auto" ]; then
        if [[ "$SERVICE_NAME" == *"_fe"* ]] || [[ "$SERVICE_NAME" == *"frontend"* ]]; then
          CONFIG_TYPE="frontend"
        else
          CONFIG_TYPE="backend"
        fi
      fi

      # Step 2: Map to actual directory
      if [ "$CONFIG_TYPE" = "frontend" ]; then
        CONFIG_DIR="${FRONTEND_CONFIG_DIR}"
      else
        CONFIG_DIR="${BACKEND_CONFIG_DIR}"
      fi

      # Step 3: Build config path
      CONFIG_PATH="config/${CONFIG_DIR}/${ENV}/${SERVICE_NAME}/application.properties"

      echo "Resolved CONFIG_TYPE: $CONFIG_TYPE"
      echo "Resolved CONFIG_DIR: $CONFIG_DIR"
      echo "Resolved CONFIG_PATH: $CONFIG_PATH"

      # Step 4: Fallback logic (VERY IMPORTANT)
      if [ ! -f "$CONFIG_PATH" ]; then
        echo " Config not found at $CONFIG_PATH"

        if [ "$CONFIG_TYPE" = "frontend" ]; then
          echo " Falling back to backend config..."

          CONFIG_DIR="${BACKEND_CONFIG_DIR}"
          CONFIG_PATH="config/${CONFIG_DIR}/${ENV}/${SERVICE_NAME}/application.properties"

          echo "Fallback CONFIG_PATH: $CONFIG_PATH"
        fi
      fi

      # Step 5: Final validation
      if [ ! -f "$CONFIG_PATH" ]; then
        echo " FINAL ERROR: Config file not found"
        echo "Checked path: $CONFIG_PATH"
        echo "Available configs:"
        ls -R config/ || true
        exit 1
      fi
      echo "CONFIG_PATH=$CONFIG_PATH" >> build.env
      
  artifacts:
    reports:
      dotenv: build.env


apiVersion: console.streamshub.github.com/v1alpha1
kind: Console
metadata:
  name: uat-console
  namespace: uat-kafka
spec:
  hostname: uat-kafkaconsole.apps.uat.epay.sbi

  kafkaClusters:
    - name: uat-kafka-cluster
      namespace: uat-kafka
      listener: plain

      credentials:
        kafkaUser:
          name: epay-user

      # ✅ Force PLAINTEXT (your cluster is non-TLS for this listener)
      properties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      adminProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      consumerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      producerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT

  # ❌ REMOVE Prometheus dependency completely
  metricsSources: []
